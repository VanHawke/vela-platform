{
  "functions": {
    "api/kiko.js": { "maxDuration": 60 },
    "api/voice.js": { "maxDuration": 60 },
    "api/health.js": { "maxDuration": 10 },
    "api/email.js": { "maxDuration": 60 },
    "api/calendar.js": { "maxDuration": 30 },
    "api/vela-code.js": { "maxDuration": 60 },
    "api/pipedrive-import.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/google-auth/callback", "destination": "/api/google-auth" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
