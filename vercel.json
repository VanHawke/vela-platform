{
  "crons": [
    { "path": "/api/cron-enrich", "schedule": "0 6 * * 1" },
    { "path": "/api/news-agent", "schedule": "0 8 * * 1-5" },
    { "path": "/api/cron-outreach-score", "schedule": "0 9 * * 1" },
    { "path": "/api/cron-partnership-scan", "schedule": "0 7 * * 1" },
    { "path": "/api/cron-document-scan", "schedule": "0 6 * * 0" }
  ],
  "functions": {
    "api/kiko.js": { "maxDuration": 60 },
    "api/voice.js": { "maxDuration": 60 },
    "api/news-agent.js": { "maxDuration": 45 },
    "api/health.js": { "maxDuration": 10 },
    "api/email.js": { "maxDuration": 30 },
    "api/calendar.js": { "maxDuration": 20 },
    "api/vela-code.js": { "maxDuration": 30 },
    "api/enrichment-agent.js": { "maxDuration": 45 },
    "api/lemlist-find-email.js": { "maxDuration": 20 },
    "api/cron-enrich.js": { "maxDuration": 45 },
    "api/cron-email-sync.js": { "maxDuration": 15 },
    "api/cron-outreach-score.js": { "maxDuration": 45 },
    "api/cron-partnership-scan.js": { "maxDuration": 45 },
    "api/documents.js": { "maxDuration": 30 },
    "api/cron-document-scan.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/google-auth/callback", "destination": "/api/google-auth" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
