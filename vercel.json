{
  "crons": [
    { "path": "/api/cron-enrich", "schedule": "0 6 * * *" },
    { "path": "/api/cron-email-sync", "schedule": "*/5 * * * *" },
    { "path": "/api/news-agent", "schedule": "*/30 * * * *" },
    { "path": "/api/cron-partnership-scan", "schedule": "0 7 * * *" }
  ],
  "functions": {
    "api/kiko.js": { "maxDuration": 60 },
    "api/voice.js": { "maxDuration": 60 },
    "api/health.js": { "maxDuration": 10 },
    "api/email.js": { "maxDuration": 60 },
    "api/calendar.js": { "maxDuration": 30 },
    "api/vela-code.js": { "maxDuration": 60 },
    "api/pipedrive-import.js": { "maxDuration": 60 },
    "api/enrichment-agent.js": { "maxDuration": 60 },
    "api/backfill-campaigns.js": { "maxDuration": 60 },
    "api/backfill-activities.js": { "maxDuration": 60 },
    "api/enrich-companies.js": { "maxDuration": 60 },
    "api/lemlist-find-email.js": { "maxDuration": 60 },
    "api/cron-enrich.js": { "maxDuration": 60 },
    "api/cron-email-sync.js": { "maxDuration": 30 },
    "api/cron-partnership-scan.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/google-auth/callback", "destination": "/api/google-auth" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
